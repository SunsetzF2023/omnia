{
  "name": "omnia",
  "version": "2.3.2",
  "description": "Omnia - 个人效率工作台",
  "main": "main.js",
  "author": "SunsetzF2023",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.sunsetz.omnia",
    "productName": "Omnia",
    "copyright": "SunsetzF2023",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "js/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "SunsetzF2023",
      "repo": "omnia"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
